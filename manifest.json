{
"manifest_version": 3,
"name": "Reels Reality Check",
"version": "1.0",
"description": "Counts Instagram reels and interrupts your scroll.",
"permissions": ["activeTab", "scripting"],
"host_permissions": ["https://www.instagram.com/*"],
"content_scripts": [
{
"matches": ["https://www.instagram.com/*"],
"js": ["content.js"],
"css": ["overlay.css"]
}
]
}
